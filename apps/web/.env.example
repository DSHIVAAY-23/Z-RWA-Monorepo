# Solana RPC endpoint
# Z-RWA uses RPC Fast for reliable high-payload ZK proof submission.
# Standard public endpoints (devnet.solana.com) reject large Groth16
# proof payloads and apply aggressive rate limits.
# Get your RPC Fast endpoint at: https://rpcfast.com
# During Frontier hackathon: apply for free Hackathon plan via RPC Fast Telegram
RPC_ENDPOINT=https://YOUR-RPC-FAST-ENDPOINT-HERE.rpcfast.com

NEXT_PUBLIC_SOLANA_NETWORK=devnet
NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_Z_RWA_PROGRAM_ID=YOUR_PROGRAM_ID_HERE
NEXT_PUBLIC_MOCK_MODE=true
